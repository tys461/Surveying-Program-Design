<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>1100</width><height>700</height></rect>
  </property>
  <property name="windowTitle">
   <string>TIN构建与填挖方体积计算系统</string>
  </property>

  <widget class="QWidget" name="centralwidget">
   <layout class="QHBoxLayout" name="hLayout">
    <item>
     <widget class="QSplitter" name="splitter">
      <property name="orientation"><enum>Qt::Horizontal</enum></property>

      <!-- 左：点云输入区 -->
      <widget class="QGroupBox" name="groupInput">
       <property name="title"><string>输入数据</string></property>
       <layout class="QVBoxLayout" name="vInput">

        <!-- 基准高程 -->
        <item>
         <layout class="QHBoxLayout" name="hHd">
          <item>
           <widget class="QLabel" name="labelHd">
            <property name="text"><string>设计基准高程 Hd (m)：</string></property>
           </widget>
          </item>
          <item>
           <widget class="QLineEdit" name="editHd">
            <property name="placeholderText"><string>例：50.000</string></property>
           </widget>
          </item>
         </layout>
        </item>

        <!-- 点云表格 -->
        <item>
         <widget class="QLabel" name="labelPts">
          <property name="text"><string>离散点坐标（x, y, z）：</string></property>
         </widget>
        </item>
        <item>
         <widget class="QTableWidget" name="tableInput">
          <property name="columnCount"><number>3</number></property>
          <property name="rowCount"><number>0</number></property>
          <attribute name="horizontalHeaderItem">
           <column>0</column>
           <widget class="QTableWidgetItem"><property name="text"><string>x (m)</string></property></widget>
          </attribute>
          <attribute name="horizontalHeaderItem">
           <column>1</column>
           <widget class="QTableWidgetItem"><property name="text"><string>y (m)</string></property></widget>
          </attribute>
          <attribute name="horizontalHeaderItem">
           <column>2</column>
           <widget class="QTableWidgetItem"><property name="text"><string>z (m)</string></property></widget>
          </attribute>
         </widget>
        </item>

       </layout>
      </widget>

      <!-- 右：结果区 -->
      <widget class="QWidget" name="widgetRight">
       <layout class="QVBoxLayout" name="vRight">

        <!-- 7项结果表格 -->
        <item>
         <widget class="QGroupBox" name="groupResult">
          <property name="title"><string>计算结果（7项）</string></property>
          <layout class="QVBoxLayout">
           <item>
            <widget class="QTableWidget" name="tableResult">
             <property name="alternatingRowColors"><bool>true</bool></property>
             <property name="editTriggers">
              <set>QAbstractItemView::NoEditTriggers</set>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>

        <!-- 三角形详情 -->
        <item>
         <widget class="QGroupBox" name="groupDetail">
          <property name="title"><string>三角形详情</string></property>
          <layout class="QVBoxLayout">
           <item>
            <widget class="QTableWidget" name="tableTriangles">
             <property name="alternatingRowColors"><bool>true</bool></property>
             <property name="editTriggers">
              <set>QAbstractItemView::NoEditTriggers</set>
             </property>
            </widget>
           </item>
          </layout>
         </widget>
        </item>

       </layout>
      </widget>

     </widget>
    </item>
   </layout>
  </widget>

  <!-- 菜单栏 -->
  <widget class="QMenuBar" name="menubar">
   <property name="geometry">
    <rect><x>0</x><y>0</y><width>1100</width><height>30</height></rect>
   </property>
   <widget class="QMenu" name="menuFile">
    <property name="title"><string>文件(&amp;F)</string></property>
    <addaction name="actionOpen"/>
    <addaction name="actionSave"/>
    <addaction name="separator"/>
    <addaction name="actionExit"/>
   </widget>
   <widget class="QMenu" name="menuOp">
    <property name="title"><string>操作(&amp;O)</string></property>
    <addaction name="actionCalc"/>
    <addaction name="separator"/>
    <addaction name="actionClear"/>
   </widget>
   <addaction name="menuFile"/>
   <addaction name="menuOp"/>
  </widget>

  <!-- 工具栏 -->
  <widget class="QToolBar" name="toolBar">
   <attribute name="toolBarArea"><enum>TopToolBarArea</enum></attribute>
   <addaction name="actionOpen"/>
   <addaction name="actionCalc"/>
   <addaction name="actionSave"/>
   <addaction name="separator"/>
   <addaction name="actionClear"/>
  </widget>

  <widget class="QStatusBar" name="statusbar"/>

  <action name="actionOpen">
   <property name="text"><string>打开数据文件(&amp;O)</string></property>
   <property name="shortcut"><string>Ctrl+O</string></property>
  </action>
  <action name="actionCalc">
   <property name="text"><string>计算(&amp;C)</string></property>
   <property name="shortcut"><string>F5</string></property>
  </action>
  <action name="actionSave">
   <property name="text"><string>保存结果(&amp;S)</string></property>
   <property name="shortcut"><string>Ctrl+S</string></property>
  </action>
  <action name="actionExit">
   <property name="text"><string>退出(&amp;Q)</string></property>
   <property name="shortcut"><string>Ctrl+Q</string></property>
  </action>
  <action name="actionClear">
   <property name="text"><string>清除</string></property>
  </action>

 </widget>
 <resources/>
 <connections/>
</ui>
